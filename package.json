{
  "name": "mcp-obsidian",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight MCP server for Obsidian REST API with proper UTF-8 and PATCH v3 support.",
  "type": "module",
  "main": "main.js",
  "bin": {
    "mcp-obsidian": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./mcp-server": "./dist/mcp-server.js",
    "./tools": "./dist/tools.js",
    "./obsidian-client": "./dist/obsidian-client.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build:plugin": "node esbuild.config.mjs production",
    "build:server": "tsc",
    "build": "npm run build:server && npm run build:plugin",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "clean": "rm -rf dist dist-test main.js",
    "version": "node version-bump.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25.12",
    "obsidian": "^1.12.3",
    "typescript": "^5.7"
  }
}
